<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cinematic Launch - Emergent</title>
  <script src="https://unpkg.com/react@18/umd/react.development.js"></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
  <style>
    body { margin: 0; font-family: 'Inter', sans-serif; overflow-x: hidden; }
    .hero-video { width: 100vw; height: 100vh; object-fit: cover; }
  </style>
</head>
<body>
  <div id="root"></div>
  <script type="text/babel">
    const { useEffect, useRef, useState } = React;

    const FloatingElements = () => {
      const elements = useRef([]);

      useEffect(() => {
        gsap.registerPlugin(ScrollTrigger);
        elements.current.forEach((el, i) => {
          gsap.to(el, {
            y: -20,
            rotation: 5,
            duration: 3 + i * 0.5,
            repeat: -1,
            yoyo: true,
            ease: "power2.inOut"
          });
        });
      }, []);

      return (
        <div className="fixed inset-0 pointer-events-none z-20">
          {[...Array(20)].map((_, i) => (
            <div 
              key={i}
              ref={el => elements.current[i] = el}
              className="absolute w-2 h-2 bg-gradient-to-r from-blue-400 to-purple-500 rounded-full opacity-60"
              style={{
                left: `${Math.random() * 100}%`,
                top: `${Math.random() * 100}%`,
                animationDelay: `${Math.random() * 2}s`
              }}
            />
          ))}
        </div>
      );
    };

    const HeroSection = () => {
      const videoRef = useRef(null);
      const titleRef = useRef(null);

      useEffect(() => {
        gsap.registerPlugin(ScrollTrigger);
        gsap.fromTo(titleRef.current, 
          { opacity: 0, y: 100 },
          { opacity: 1, y: 0, duration: 1.5, ease: "power3.out" }
        );
      }, []);

      return (
        <section className="relative h-screen flex items-center justify-center overflow-hidden">
          <video 
            ref={videoRef}
            className="hero-video"
            autoPlay 
            muted 
            loop
            playsInline
            poster="https://images.unsplash.com/photo-1516321497487-e288fb19713f?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80"
          >
            <source src="https://assets.mixkit.co/videos/preview/mixkit-waves-reach-the-coast-under-a-full-moon-5109-large.mp4" type="video/mp4" />
          </video>
          <div className="absolute inset-0 bg-gradient-to-b from-black/50 to-black/80" />
          <FloatingElements />
          <div className="relative z-10 text-center text-white px-4 max-w-4xl mx-auto">
            <h1 ref={titleRef} className="text-6xl md:text-8xl font-black bg-gradient-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent mb-8 drop-shadow-2xl">
              CINEMATIC
            </h1>
            <p className="text-xl md:text-2xl opacity-90 mb-12 max-w-2xl mx-auto leading-relaxed">
              Scroll-choreographed landing for media launches. Built for design teams who demand precision.
            </p>
            <div className="flex flex-col sm:flex-row gap-6 justify-center">
              <button className="px-12 py-4 bg-gradient-to-r from-blue-500 to-purple-600 text-white font-bold rounded-full text-lg shadow-2xl hover:shadow-3xl transform hover:scale-105 transition-all duration-300">
                Watch Trailer
              </button>
              <button className="px-12 py-4 border-2 border-white/50 text-white font-bold rounded-full text-lg backdrop-blur-sm hover:bg-white/10 transition-all duration-300">
                Learn More
              </button>
            </div>
          </div>
        </section>
      );
    };

    const FeatureSection = () => {
      useEffect(() => {
        gsap.registerPlugin(ScrollTrigger);
        gsap.utils.toArray('.feature-card').forEach((card, i) => {
          gsap.fromTo(card, 
            { opacity: 0, scale: 0.8, y: 50 },
            {
              opacity: 1,
              scale: 1,
              y: 0,
              duration: 1,
              scrollTrigger: {
                trigger: card,
                start: "top 85%",
                toggleActions: "play none none reverse"
              }
            }
          );
        });
      }, []);

      return (
        <section className="py-32 px-8 bg-gradient-to-b from-slate-900 to-black">
          <div className="max-w-6xl mx-auto">
            <div className="text-center mb-32">
              <h2 className="text-5xl md:text-7xl font-black bg-gradient-to-r from-white to-slate-300 bg-clip-text text-transparent mb-8">
                Precision
              </h2>
              <p className="text-xl md:text-2xl max-w-3xl mx-auto opacity-80">
                Every scroll, every frame, perfectly choreographed. No compromises.
              </p>
            </div>
            <div className="grid md:grid-cols-3 gap-12">
              <div className="feature-card p-12 rounded-3xl bg-white/5 backdrop-blur-xl border border-white/20 hover:border-white/40 transition-all duration-500 group">
                <div className="w-20 h-20 bg-gradient-to-r from-blue-500 to-purple-600 rounded-2xl flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-300">
                  <svg className="w-10 h-10" fill="white" viewBox="0 0 24 24">
                    <path d="M12 2L13.09 8.26L19 9L15.5 12.74L16.59 19L12 16.26L7.41 19L8.5 12.74L5 9L10.91 8.26L12 2Z"/>
                  </svg>
                </div>
                <h3 className="text-3xl font-black mb-6 text-white group-hover:text-blue-400 transition-colors">
                  Scroll Magic
                </h3>
                <p className="text-lg opacity-80 leading-relaxed">
                  Parallax depth, pin effects, scrub timelines. GSAP ScrollTrigger perfection.
                </p>
              </div>
              <div className="feature-card p-12 rounded-3xl bg-white/5 backdrop-blur-xl border border-white/20 hover:border-white/40 transition-all duration-500 group">
                <div className="w-20 h-20 bg-gradient-to-r from-green-500 to-emerald-600 rounded-2xl flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-300">
                  <svg className="w-10 h-10" fill="white" viewBox="0 0 24 24">
                    <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                  </svg>
                </div>
                <h3 className="text-3xl font-black mb-6 text-white group-hover:text-emerald-400 transition-colors">
                  60fps Smooth
                </h3>
                <p className="text-lg opacity-80 leading-relaxed">
                  Optimized transforms, GPU acceleration. Lightning fast even on mobile.
                </p>
              </div>
              <div className="feature-card p-12 rounded-3xl bg-white/5 backdrop-blur-xl border border-white/20 hover:border-white/40 transition-all duration-500 group">
                <div className="w-20 h-20 bg-gradient-to-r from-orange-500 to-red-600 rounded-2xl flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-300">
                  <svg className="w-10 h-10" fill="white" viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                  </svg>
                </div>
                <h3 className="text-3xl font-black mb-6 text-white group-hover:text-orange-400 transition-colors">
                  Responsive
                </h3>
                <p className="text-lg opacity-80 leading-relaxed">
                  Mobile-first, tablet-optimized, desktop epic. Tailwind + React perfection.
                </p>
              </div>
            </div>
          </div>
        </section>
      );
    };

    const CTASection = () => {
      useEffect(() => {
        gsap.registerPlugin(ScrollTrigger);
        gsap.fromTo('.cta-card', 
          { opacity: 0, scale: 0.9 },
          {
            opacity: 1,
            scale: 1,
            duration: 1.2,
            stagger: 0.2,
            scrollTrigger: {
              trigger: '.cta-section',
              start: "top 80%"
            }
          }
        );
      }, []);

      return (
        <section className="cta-section py-32 px-8 bg-gradient-to-t from-black to-slate-900 relative overflow-hidden">
          <div className="max-w-4xl mx-auto text-center">
            <h2 className="text-5xl md:text-7xl font-black bg-gradient-to-r from-white via-slate-200 to-slate-400 bg-clip-text text-transparent mb-12">
              Ready to Launch?
            </h2>
            <div className="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
              <div className="cta-card p-12 rounded-3xl bg-gradient-to-br from-blue-500/20 to-purple-600/20 backdrop-blur-xl border border-blue-400/30 hover:shadow-3xl transition-all duration-500">
                <h3 className="text-3xl font-black mb-6 text-white">Design Teams</h3>
                <p className="text-xl opacity-90 mb-8 leading-relaxed">
                  Copy, customize, ship. No dev handoff needed.
                </p>
                <button className="px-10 py-4 bg-white text-blue-600 font-bold rounded-2xl text-lg hover:shadow-xl transform hover:scale-105 transition-all duration-300">
                  Start Free
                </button>
              </div>
              <div className="cta-card p-12 rounded-3xl bg-gradient-to-br from-emerald-500/20 to-teal-600/20 backdrop-blur-xl border border-emerald-400/30 hover:shadow-3xl transition-all duration-500">
                <h3 className="text-3xl font-black mb-6 text-white">Marketing</h3>
                <p className="text-xl opacity-90 mb-8 leading-relaxed">
                  Convert visitors at scale. Built for performance.
                </p>
                <button className="px-10 py-4 bg-white text-emerald-600 font-bold rounded-2xl text-lg hover:shadow-xl transform hover:scale-105 transition-all duration-300">
                  View Demos
                </button>
              </div>
            </div>
          </div>
        </section>
      );
    };

    const App = () => (
      <div>
        <HeroSection />
        <FeatureSection />
        <CTASection />
      </div>
    );

    ReactDOM.render(<App />, document.getElementById('root'));
  </script>
</body>
</html>
